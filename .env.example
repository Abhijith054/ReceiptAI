# Optional: Groq API key for LLM-based question answering
# Get a free key at https://console.groq.com/
# If not set, a rule-based QA fallback will be used
GROQ_API_KEY=your_groq_api_key_here

# Model configuration
MODEL_NAME=distilbert-base-uncased
MODEL_OUTPUT_DIR=models/receipt_ner

# Data paths
DATA_DIR=data
RECORDS_FILE=data/extracted_records.jsonl
DATA_DIR=postgresql://postgres:[]@db..supabase.copostgres
